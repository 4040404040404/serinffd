# ── RPC / fork ──────────────────────────────────────────────────────────────
# Sepolia JSON-RPC endpoint (Alchemy / Infura / your own node)
ETH_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Deployment ───────────────────────────────────────────────────────────────
# Private key of the account that will deploy and own the contract
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Etherscan key for contract verification
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY

# ── Keeper ───────────────────────────────────────────────────────────────────
# Address of the deployed FlashArbLeverage contract
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Tokens to arbitrage (Sepolia: Aave-faucet USDC / WETH)
TOKEN_IN=0x94a9D9AC8a22534E3FaCa9F4e7F2E2cf85d5E4C8
TOKEN_OUT=0xC558DBdd856501FCd9aaF1E62eae57A9F0629a3c

# Flash loan size in TOKEN_IN units (6-decimal USDC example: 1 000 000 USDC)
FLASH_AMOUNT=1000000000000

# Minimum profit (in TOKEN_IN units) before Aave deposit is triggered
MIN_PROFIT=0

# Uniswap V3 fee tiers for the two swap legs (500 = 0.05 %, 3000 = 0.3 %)
FEE0=500
FEE1=3000
